<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MinesweeperApp"
             xmlns:vm="clr-namespace:MinesweeperApp.ViewModels"
             x:Class="MinesweeperApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <vm:BoolToFlagTextConverter x:Key="BoolToFlagTextConverter"/>
            <vm:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <vm:BoolToInstructionConverter x:Key="BoolToInstructionConverter"/>
            <vm:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
