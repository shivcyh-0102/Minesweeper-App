<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MinesweeperApp.ViewModels"
             xmlns:m="clr-namespace:MinesweeperApp.Models"
             x:Class="MinesweeperApp.MainPage"
             BackgroundColor="#0F0F23">

    <ContentPage.Resources>
        <ResourceDictionary>
            <vm:BoolToFlagTextConverter x:Key="BoolToFlagTextConverter"/>
            <vm:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <vm:BoolToInstructionConverter x:Key="BoolToInstructionConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:GameViewModel/>
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*"
          ColumnDefinitions="*">
        <!-- Main Content -->
        <VerticalStackLayout Grid.Row="0"
                             Grid.Column="0"
                             Padding="16"
                             Spacing="16">

            <!-- Start/Difficulty Selection Screen -->
            <VerticalStackLayout x:Name="StartScreen"
                                 IsVisible="{Binding IsGameStarted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}"
                                 VerticalOptions="Center"
                                 Spacing="24">

                <!-- Title -->
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center">
                    <Label Text="💣"
                           FontSize="64"
                           HorizontalOptions="Center"
                           Margin="0,0,0,8"/>
                    <Label Text="MINESWEEPER"
                           TextColor="#FFFFFF"
                           FontSize="42"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Find all the mines without exploding!"
                           TextColor="#B0B0D0"
                           FontSize="15"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Difficulty Selection -->
                <VerticalStackLayout x:Name="DifficultyScreen"
                                     IsVisible="{Binding IsDifficultySelectionVisible}"
                                     Spacing="16">

                    <Label Text="Select Difficulty"
                           TextColor="#FFFFFF"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,16,0,0"/>

                    <!-- Easy Button -->
                    <Border BackgroundColor="#1E88E5"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="100">
                        <Grid Padding="20"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="EASY"
                                       TextColor="#FFFFFF"
                                       FontSize="18"
                                       FontAttributes="Bold"/>
                                <Label Text="9x9, 10 mines"
                                       TextColor="#B3E5FC"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="⭐"
                                   FontSize="36"
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectDifficultyCommand}"
                                                      CommandParameter="{x:Static m:DifficultyLevel.Easy}"/>
                            </Border.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Medium Button -->
                    <Border BackgroundColor="#F57C00"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="100">
                        <Grid Padding="20"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="MEDIUM"
                                       TextColor="#FFFFFF"
                                       FontSize="18"
                                       FontAttributes="Bold"/>
                                <Label Text="16x16, 40 mines"
                                       TextColor="#FFE0B2"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="⭐⭐"
                                   FontSize="36"
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectDifficultyCommand}"
                                                      CommandParameter="{x:Static m:DifficultyLevel.Medium}"/>
                            </Border.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Hard Button -->
                    <Border BackgroundColor="#D32F2F"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="100">
                        <Grid Padding="20"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="HARD"
                                       TextColor="#FFFFFF"
                                       FontSize="18"
                                       FontAttributes="Bold"/>
                                <Label Text="30x16, 99 mines"
                                       TextColor="#FFCDD2"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="⭐⭐⭐"
                                   FontSize="36"
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectDifficultyCommand}"
                                                      CommandParameter="{x:Static m:DifficultyLevel.Hard}"/>
                            </Border.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Best Times -->
                    <VerticalStackLayout Spacing="8"
                                         Margin="0,20,0,0">
                        <Label Text="🏆 Best Times"
                               TextColor="#FFFFFF"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="#1a1a32"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1"
                                    Stroke="#3a3a5a"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4"
                                                     HorizontalOptions="Center">
                                    <Label Text="Easy"
                                           TextColor="#B0B0D0"
                                           FontSize="12"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding BestTimeEasy}"
                                           TextColor="#1E88E5"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    BackgroundColor="#1a1a32"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1"
                                    Stroke="#3a3a5a"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4"
                                                     HorizontalOptions="Center">
                                    <Label Text="Medium"
                                           TextColor="#B0B0D0"
                                           FontSize="12"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding BestTimeMedium}"
                                           TextColor="#F57C00"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2"
                                    BackgroundColor="#1a1a32"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1"
                                    Stroke="#3a3a5a"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4"
                                                     HorizontalOptions="Center">
                                    <Label Text="Hard"
                                           TextColor="#B0B0D0"
                                           FontSize="12"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding BestTimeHard}"
                                           TextColor="#D32F2F"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Quit Button -->
                <Button Text="❌ QUIT"
                        Command="{Binding QuitGameCommand}"
                        BackgroundColor="#424242"
                        TextColor="White"
                        CornerRadius="24"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="54"
                        WidthRequest="200"
                        HorizontalOptions="Center"
                        Margin="0,16,0,0"/>

            </VerticalStackLayout>

            <!-- Game Screen -->
            <VerticalStackLayout x:Name="GameScreen"
                                 IsVisible="{Binding IsGameStarted}"
                                 Spacing="12">

                <!-- Header with Timer and Mines -->
                <Border BackgroundColor="#1a1a32"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1"
                        Stroke="#3a3a5a"
                        Padding="16">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                          ColumnSpacing="12">
                        <!-- Mines Counter -->
                        <Border Grid.Column="0"
                                BackgroundColor="#D32F2F"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                Padding="12">
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center">
                                <Label Text="💣"
                                       FontSize="18"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding MinesLeft}"
                                       FontSize="16"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Status Message -->
                        <Label Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               FontSize="14"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"/>

                        <!-- Timer -->
                        <Border Grid.Column="2"
                                BackgroundColor="#1E88E5"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                Padding="12">
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center">
                                <Label Text="⏱️"
                                       FontSize="18"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding FormattedTime}"
                                       FontSize="16"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Flag Mode Button -->
                        <Button Grid.Column="3"
                                Text="{Binding IsFlagMode, Converter={StaticResource BoolToFlagTextConverter}}"
                                Command="{Binding ToggleFlagModeCommand}"
                                BackgroundColor="{Binding IsFlagMode, Converter={StaticResource BoolToColorConverter}}"
                                TextColor="White"
                                CornerRadius="12"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="44"
                                WidthRequest="50"/>

                        <!-- Restart Button -->
                        <Button Grid.Column="4"
                                Text="🔄"
                                Command="{Binding RestartCommand}"
                                BackgroundColor="#FF8F00"
                                TextColor="White"
                                CornerRadius="12"
                                FontSize="16"
                                HeightRequest="44"
                                WidthRequest="50"/>
                    </Grid>
                </Border>

                <!-- Scroll View for Game Board -->
                <ScrollView Padding="0">
                    <CollectionView ItemsSource="{Binding Cells}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="9"
                                             HorizontalItemSpacing="4"
                                             VerticalItemSpacing="4"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{Binding BackgroundColor}"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="2"
                                        Stroke="#2a2a4a"
                                        Padding="0"
                                        HeightRequest="38"
                                        WidthRequest="38">
                                    <Label Text="{Binding DisplayText}"
                                           TextColor="{Binding TextColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           FontSize="15"
                                           FontAttributes="Bold"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RevealCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>

                <!-- Instructions -->
                <Label Text="{Binding IsFlagMode, Converter={StaticResource BoolToInstructionConverter}}"
                       TextColor="#B0B0D0"
                       HorizontalOptions="Center"
                       FontSize="12"
                       Margin="0,8,0,0"/>

                <!-- Back Button -->
                <Button Text="← Back to Menu"
                        Command="{Binding BackToDifficultyCommand}"
                        BackgroundColor="#424242"
                        TextColor="White"
                        CornerRadius="20"
                        FontSize="14"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        Margin="0,12,0,0"/>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>