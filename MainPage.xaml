<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MinesweeperApp.ViewModels"
             xmlns:m="clr-namespace:MinesweeperApp.Models"
             x:Class="MinesweeperApp.MainPage"
             BackgroundColor="#0F0F23">

    <ContentPage.BindingContext>
        <vm:GameViewModel/>
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*"
          ColumnDefinitions="*">
        <!-- Main Content -->
        <VerticalStackLayout Grid.Row="0"
                             Grid.Column="0"
                             Padding="16"
                             Spacing="16">

            <!-- Start/Difficulty Selection Screen -->
            <VerticalStackLayout x:Name="StartScreen"
                                 IsVisible="{Binding IsGameStarted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}"
                                 VerticalOptions="Center"
                                 Spacing="24">

                <!-- Title -->
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center">
                    <Label Text="💣"
                           FontSize="64"
                           HorizontalOptions="Center"
                           Margin="0,0,0,8"/>
                    <Label Text="MINESWEEPER"
                           TextColor="#FFFFFF"
                           FontSize="42"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Find all the mines without exploding!"
                           TextColor="#B0B0D0"
                           FontSize="15"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Difficulty Selection -->
                <VerticalStackLayout x:Name="DifficultyScreen"
                                     IsVisible="{Binding IsDifficultySelectionVisible}"
                                     Spacing="16">

                    <Label Text="Select Difficulty"
                           TextColor="#FFFFFF"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,16,0,0"/>

                    <!-- Easy Button -->
                    <Border BackgroundColor="#1E88E5"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="100">
                        <Grid Padding="20"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="EASY"
                                       TextColor="#FFFFFF"
                                       FontSize="18"
                                       FontAttributes="Bold"/>
                                <Label Text="9x9, 10 mines"
                                       TextColor="#B3E5FC"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="⭐"
                                   FontSize="36"
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectDifficultyCommand}"
                                                      CommandParameter="{x:Static m:DifficultyLevel.Easy}"/>
                            </Border.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Medium Button -->
                    <Border BackgroundColor="#F57C00"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="100">
                        <Grid Padding="20"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="MEDIUM"
                                       TextColor="#FFFFFF"
                                       FontSize="18"
                                       FontAttributes="Bold"/>
                                <Label Text="16x16, 40 mines"
                                       TextColor="#FFE0B2"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="⭐⭐"
                                   FontSize="36"
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectDifficultyCommand}"
                                                      CommandParameter="{x:Static m:DifficultyLevel.Medium}"/>
                            </Border.GestureRecognizers>
                        </Grid>
                    </Border>



                    <!-- Best Times -->
                    <VerticalStackLayout Spacing="8"
                                         Margin="0,20,0,0">
                        <Label Text="🏆 Best Times"
                               TextColor="#FFFFFF"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="#1a1a32"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1"
                                    Stroke="#3a3a5a"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4"
                                                     HorizontalOptions="Center">
                                    <Label Text="Easy"
                                           TextColor="#B0B0D0"
                                           FontSize="12"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding BestTimeEasy}"
                                           TextColor="#1E88E5"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    BackgroundColor="#1a1a32"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1"
                                    Stroke="#3a3a5a"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4"
                                                     HorizontalOptions="Center">
                                    <Label Text="Medium"
                                           TextColor="#B0B0D0"
                                           FontSize="12"
                                           HorizontalOptions="Center"/>
                                    <Label Text="{Binding BestTimeMedium}"
                                           TextColor="#F57C00"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Quit Button -->
                <Button Text="❌ QUIT"
                        Command="{Binding QuitGameCommand}"
                        BackgroundColor="#424242"
                        TextColor="White"
                        CornerRadius="24"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="54"
                        WidthRequest="200"
                        HorizontalOptions="Center"
                        Margin="0,16,0,0"/>

            </VerticalStackLayout>

            <!-- Game Screen -->
            <VerticalStackLayout x:Name="GameScreen"
                                 IsVisible="{Binding IsGameStarted}"
                                 Spacing="8"
                                 Padding="8,12,8,8"
                                 VerticalOptions="FillAndExpand">

                <!-- Header with Timer and Mines -->
                <Border BackgroundColor="#1a1a32"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="#3a3a5a"
                        Padding="12,10,12,10">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10">
                        <!-- Status Message -->
                        <Label Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               FontSize="13"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Start"
                               VerticalOptions="Center"
                               FontAttributes="Bold"/>

                        <!-- Mines Counter -->
                        <Border Grid.Column="1"
                                BackgroundColor="#D32F2F"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Padding="10,6,10,6">
                            <HorizontalStackLayout Spacing="4"
                                                   VerticalOptions="Center">
                                <Label Text="💣"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding MinesLeft}"
                                       FontSize="12"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Timer -->
                        <Border Grid.Column="2"
                                BackgroundColor="#1E88E5"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Padding="10,6,10,6">
                            <HorizontalStackLayout Spacing="4"
                                                   VerticalOptions="Center">
                                <Label Text="⏱️"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding FormattedTime}"
                                       FontSize="12"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Flag Mode Button -->
                        <Button Grid.Column="3"
                                Text="{Binding IsFlagMode, Converter={StaticResource BoolToFlagTextConverter}}"
                                Command="{Binding ToggleFlagModeCommand}"
                                BackgroundColor="{Binding IsFlagMode, Converter={StaticResource BoolToColorConverter}}"
                                TextColor="White"
                                CornerRadius="10"
                                FontSize="14"
                                FontAttributes="Bold"
                                HeightRequest="36"
                                WidthRequest="40"
                                Padding="0"/>

                        <!-- Restart Button -->
                        <Button Grid.Column="4"
                                Text="🔄"
                                Command="{Binding RestartCommand}"
                                BackgroundColor="#FF8F00"
                                TextColor="White"
                                CornerRadius="10"
                                FontSize="14"
                                HeightRequest="36"
                                WidthRequest="40"
                                Padding="0"/>
                    </Grid>
                </Border>

                <!-- Game Board Container -->
                <Border BackgroundColor="#1a1a32"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="#3a3a5a"
                        Padding="8"
                        VerticalOptions="FillAndExpand"
                        HorizontalOptions="Center">
                    <Grid RowDefinitions="*"
                          ColumnDefinitions="*"
                          Padding="0">
                        <CollectionView Grid.Row="0"
                                        ItemsSource="{Binding Cells}"
                                        SelectionMode="None"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical"
                                                 Span="{Binding GridColumns}"
                                                 HorizontalItemSpacing="3"
                                                 VerticalItemSpacing="3"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{Binding BackgroundColor}"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="1.5"
                                            Stroke="#2a2a4a"
                                            Padding="0"
                                            HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CellSize}"
                                            WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CellSize}">
                                        <Label Text="{Binding DisplayText}"
                                               TextColor="{Binding TextColor}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               FontSize="13"
                                               FontAttributes="Bold"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RevealCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <!-- Instructions -->
                <Label Text="{Binding IsFlagMode, Converter={StaticResource BoolToInstructionConverter}}"
                       TextColor="#A0A0C0"
                       HorizontalOptions="Center"
                       FontSize="11"
                       Margin="0,4,0,4"/>

                <!-- Footer Buttons -->
                <HorizontalStackLayout Spacing="8"
                                       HorizontalOptions="Center"
                                       Margin="0,8,0,0">
                    <!-- Back Button -->
                    <Border BackgroundColor="#2C3E50"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="#3a3a5a"
                            Padding="0"
                            WidthRequest="180"
                            HeightRequest="44">
                        <Button Text="← Back to Menu"
                                Command="{Binding BackToDifficultyCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#FFFFFF"
                                FontSize="14"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>